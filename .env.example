# ---------------------------------------------------------------------------
# EcoTrack environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored so your secrets never leave your machine.
#
# The application is fully functional WITHOUT any key: it falls back to a
# built-in, rule-based insights engine. Adding a Gemini key simply upgrades the
# personalized insights to AI-generated guidance.
# ---------------------------------------------------------------------------

# Google Gemini API key (free tier available at https://aistudio.google.com/apikey).
# This key is read ONLY on the server (in the /api/insights route) and is never
# exposed to the browser.
GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to "gemini-2.5-flash".
GEMINI_MODEL=gemini-2.5-flash

# Optional: canonical site URL used for SEO metadata, robots.txt, and sitemap.
# Set this to your deployed domain in production (e.g. https://ecotrack.app).
NEXT_PUBLIC_SITE_URL=
